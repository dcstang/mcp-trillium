# --- Trilium API ---
TRILIUM_API_KEY=your_api_key_here
# URL of the Trilium ETAPI, as seen from the MCP container.
# If MCP and Trilium are in the same docker-compose network, use the service name:
TRILIUM_BASE_URL=http://trilium:37840/etapi

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=8000
LOG_PATH=/app/logs/debug.log
# Your VPS Tailscale IP (run: tailscale ip -4).
# The port is bound to this IP only — it will NOT be reachable from the public internet.
TAILSCALE_IP=100.x.x.x

# --- Backups ---
TRILIUM_VOLUME_NAME=trilium_data
BACKUP_DIR=/opt/backups/trilium
# rclone remote:path — configure with: rclone config
RCLONE_REMOTE=remote:trilium-backups
RETENTION_DAYS=7
